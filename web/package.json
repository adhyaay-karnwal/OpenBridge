{
  "name": "openbridge",
  "type": "module",
  "packageManager": "yarn@4.9.1",
  "description": "openbridge Web",
  "scripts": {
    "build": "yarn build:embedded",
    "build:embedded": "yarn build:chat && yarn build:preview",
    "lint:fix": "oxlint -c .oxlintrc.json --fix --deny-warnings && prettier --ignore-unknown --cache --write .",
    "lint": "oxlint -c .oxlintrc.json --deny-warnings && prettier --ignore-unknown --cache --check .",
    "dev": "rspack serve --configName chat --mode development",
    "dev:chat": "rspack --watch --configName chat --mode development",
    "dev:preview": "rspack --watch --configName preview --mode development",
    "serve:chat": "rspack serve --configName chat --mode development",
    "serve:preview": "rspack serve --configName preview --mode development",
    "build:chat": "rspack build --configName chat --mode production",
    "build:preview": "rspack build --configName preview --mode production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf ../macos/OpenBridge/Helpers/WebKitBridgeUI/WebKitBridgeResources/ChatAssets ../macos/OpenBridge/Helpers/WebKitBridgeUI/WebKitBridgeResources/PreviewAssets"
  },
  "devDependencies": {
    "@rspack/cli": "^1.5.8",
    "@rspack/core": "^1.5.8",
    "@rspack/plugin-html": "^0.5.8",
    "@rspack/postcss-loader": "^0.2.12",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/flubber": "^0.4.0",
    "@types/lodash": "^4.17.20",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "clsx": "^2.1.1",
    "css-loader": "^7.1.2",
    "jsdom": "^29.0.1",
    "oxlint": "^1.23.0",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.6.2",
    "style-loader": "^4.0.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.1.0",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-virtual": "^3.13.18",
    "animejs": "^4.3.5",
    "flubber": "^0.4.2",
    "framer-motion": "^12.23.24",
    "hast": "^1.0.0",
    "katex": "^0.16.25",
    "lodash": "^4.17.21",
    "lucide-react": "^0.545.0",
    "mermaid": "^11.12.2",
    "motion": "^12.23.24",
    "partial-json": "^0.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype-harden": "^1.0.4",
    "shiki": "^3.19.0",
    "streamdown": "^2.4.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.12"
  }
}
