set shell := ["zsh", "-cu"]

default:
    @just --list

package-resolve:
    swift package resolve

build:
    swift build

test:
    swift test

format-lint:
    if command -v swift-format >/dev/null 2>&1; then \
        swift-format lint --recursive Sources Tests; \
    elif swift format lint --help >/dev/null 2>&1; then \
        swift format lint --recursive Sources Tests; \
    else \
        echo "swift-format is unavailable" >&2; \
        exit 1; \
    fi

tccu-install:
    TCCUTIL_INSTALL_DIR="${TCCUTIL_INSTALL_DIR:-/usr/local/bin}" \
    ./Scripts/install-tccutil.zsh

tccu-grant:
    demo_bin_path="${GRANT_BINARY:-$(swift build --product ComputerUse --configuration release && echo $(pwd)/.build/release/ComputerUse)}"
    GRANT_BINARY="${demo_bin_path}" \
    GRANT_SCOPE="${GRANT_SCOPE:-user}" \
    GRANT_USER="${GRANT_USER:-}" \
    GRANT_SERVICES="${GRANT_SERVICES:-kTCCServiceAccessibility kTCCServiceScreenCapture}" \
    GRANT_CHECK_COMMAND="${GRANT_CHECK_COMMAND:-}" \
    GRANT_DRY_RUN="${GRANT_DRY_RUN:-0}" \
    GRANT_TCCUTIL="${GRANT_TCCUTIL:-}" \
    ./Scripts/grant-permissions.zsh

bootstrap-signing:
    ./Scripts/bootstrap-signing.zsh

bundle-app:
    ./Scripts/make-app-bundle.zsh

install-app: bundle-app
    dest="${HOME}/Applications" && mkdir -p "${dest}" && rm -rf "${dest}/ComputerUse.app" && cp -R .build/apps/ComputerUse.app "${dest}/ComputerUse.app" && echo "installed to ${dest}/ComputerUse.app"

check: package-resolve build test

check-full: format-lint check

must-run: check
