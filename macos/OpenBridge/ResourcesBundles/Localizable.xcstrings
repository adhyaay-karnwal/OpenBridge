    "This will delete all VM overlay images and restart the app to apply changes." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden alle VM-Overlay-Images gelöscht und die App neu gestartet, um die Änderungen anzuwenden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will delete all VM overlay images and restart the app to apply changes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará todas las imágenes de superposición de VM y reiniciará la aplicación para aplicar los cambios."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
