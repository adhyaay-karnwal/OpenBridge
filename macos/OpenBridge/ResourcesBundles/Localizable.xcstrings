    "Leave empty to use the default endpoint. Only change this if you're using a proxy or custom endpoint." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leer lassen, um den Standard-Endpunkt zu verwenden. Ändern Sie dies nur, wenn Sie einen Proxy oder benutzerdefinierten Endpunkt verwenden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leave empty to use the default endpoint. Only change this if you're using a proxy or custom endpoint."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deja vacío para usar el punto final predeterminado. Solo cambia esto si usas un proxy o punto final personalizado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Laissez vide pour utiliser le point de terminaison par défaut. Modifiez uniquement si vous utilisez un proxy ou un point de terminaison personnalisé."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デフォルトのエンドポイントを使用するには空のままにしてください。プロキシまたはカスタムエンドポイントを使用する場合のみ変更してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기본 엔드포인트를 사용하려면 비워 두세요. 프록시 또는 사용자 지정 엔드포인트를 사용하는 경우에만 변경하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果使用默认端点，请留空。仅在使用代理或自定义端点时更改。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果使用預設端點，請留空。僅在使用代理伺服器或自訂端點時更改。"
          }
        }
      }
    },
