    "Configure your own API keys to use AI models directly. When enabled, requests will use your API key instead of the default service." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konfigurieren Sie Ihre eigenen API-Schlüssel, um KI-Modelle direkt zu verwenden. Bei Aktivierung werden Anfragen Ihren API-Schlüssel anstelle des Standarddienstes verwenden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configure your own API keys to use AI models directly. When enabled, requests will use your API key instead of the default service."
