          }
        }
      }
    },
    "Your API key is never stored on our servers and is used solely for the duration of each request." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr API-Schlüssel wird niemals auf unseren Servern gespeichert und wird nur für die Dauer jeder Anfrage verwendet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your API key is never stored on our servers and is used solely for the duration of each request."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu clave API nunca se almacena en nuestros servidores y solo se usa durante cada solicitud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre clé API n'est jamais stockée sur nos serveurs et est utilisée uniquement pendant la durée de chaque requête."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "APIキーは弊社のサーバーに保存されることはなく、各リクエストの間のみ使用されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "API 키는 서버에 저장되지 않으며 각 요청 기간 동안만 사용됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的 API 密钥绝不会存储在我们的服务器上，仅在每次请求期间使用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的 API 金鑰絕不會儲存在我們的伺服器上，僅在每次請求期間使用。"
          }
        }
      }
    },
    "Your API key is stored locally and transmitted to our server only when making AI requests. This allows you to leverage OpenBridge's full capabilities including conversation management and advanced features." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr API-Schlüssel wird lokal gespeichert und nur bei KI-Anfragen an unseren Server übertragen. Dies ermöglicht Ihnen, die vollen Funktionen von OpenBridge einschließlich Konversationsverwaltung und erweiterten Funktionen zu nutzen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your API key is stored locally and transmitted to our server only when making AI requests. This allows you to leverage OpenBridge's full capabilities including conversation management and advanced features."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu clave API se almacena localmente y se transmite a nuestro servidor solo al realizar solicitudes de IA. Esto te permite aprovechar todas las capacidades de OpenBridge, incluida la gestión de conversaciones y funciones avanzadas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre clé API est stockée localement et transmise à notre serveur uniquement lors des requêtes IA. Cela vous permet de profiter de toutes les capacités de OpenBridge, y compris la gestion des conversations et les fonctionnalités avancées."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "APIキーはローカルに保存され、AIリクエストを行う際にのみサーバーに送信されます。これにより、会話管理や高度な機能を含むOpenBridgeの全機能を活用できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "API 키는 로컬에 저장되며 AI 요청 시에만 서버로 전송됩니다. 이를 통해 대화 관리 및 고급 기능을 포함한 OpenBridge의 모든 기능을 활용할 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的 API 密钥会被本地存储，并仅在进行 AI 请求时传输到我们的服务器。这使您能够利用 OpenBridge 的全部功能，包括对话管理和高级功能。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的 API 金鑰會被本地存儲，並僅在進行 AI 請求時傳輸到我們的伺服器。這使您能夠利用 OpenBridge 的全部功能，包括對話管理和高級功能。"
          }
        }
      }
    },
    "Your main language preference. This will be prioritized during OCR and AI operations." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
