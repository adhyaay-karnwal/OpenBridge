      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn aktiviert, versucht Vision, die Sprache automatisch zu erkennen, wobei Ihre ausgewählten Sprachen weiterhin priorisiert werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When enabled, Vision will try to detect language automatically while still prioritizing your selected languages."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando está habilitado, Vision intentará detectar el idioma automáticamente mientras prioriza tus idiomas seleccionados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque activé, Vision essaiera de détecter automatiquement la langue tout en priorisant vos langues sélectionnées."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、Visionは選択した言語を優先しながら、言語を自動的に検出しようとします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "활성화하면 Vision이 선택한 언어를 우선시하면서 자동으로 언어를 감지합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启用后，Vision 将尝试自动检测语言，同时仍优先考虑您选择的语言。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟用後，Vision 將嘗試自動檢測語言，同時仍優先考慮您選擇的語言。"
          }
        }
      }
    },
    "Width budget for each compact side slot. Slot content is clamped to this space so it does not collide with the physical notch." : {},
