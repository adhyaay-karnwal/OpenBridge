    "You have unsaved changes. Would you like to save them?" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie haben nicht gespeicherte Änderungen. Möchten Sie sie speichern?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You have unsaved changes. Would you like to save them?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiene cambios sin guardar. ¿Desea guardarlos?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez des modifications non enregistrées. Voulez-vous les enregistrer ?"
          }
