    "Sync skills from any folder you use. Select a folder from another app, and we'll automatically monitor and keep your skills synchronized." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Synchronisieren Sie Skills aus jedem Ordner, den Sie verwenden. Wählen Sie einen Ordner aus einer anderen App, und wir überwachen und synchronisieren Ihre Skills automatisch."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sync skills from any folder you use. Select a folder from another app, and we'll automatically monitor and keep your skills synchronized."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sincroniza habilidades desde cualquier carpeta que uses. Selecciona una carpeta de otra aplicación y monitorearemos y sincronizaremos tus habilidades automáticamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Synchronisez les compétences depuis n'importe quel dossier que vous utilisez. Sélectionnez un dossier d'une autre application, et nous surveillerons et synchroniserons automatiquement vos compétences."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用している任意のフォルダからスキルを同期します。別のアプリからフォルダを選択すると、自動的に監視してスキルを同期します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사용하는 모든 폴더에서 스킬을 동기화합니다. 다른 앱에서 폴더를 선택하면 자동으로 모니터링하고 스킬을 동기화합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从您使用的任何文件夹同步 Skill。选择另一个应用中的文件夹，我们将自动监控并保持您的 Skill 同步。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "從您使用的任何資料夾同步 Skill。選擇另一個應用程式中的資料夾，我們將自動監控並保持您的 Skill 同步。"
          }
        }
      }
    },
