        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configura tus propias claves API para usar modelos de IA directamente. Cuando está habilitado, las solicitudes usarán tu clave API en lugar del servicio predeterminado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configurez vos propres clés API pour utiliser les modèles IA directement. Lorsque activé, les requêtes utiliseront votre clé API au lieu du service par défaut."
