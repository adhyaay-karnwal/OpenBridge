    "The keychain environment has a problem. Please open Keychain Access, search for \"%@\", delete all matching items, then relaunch the app." : {
      "comment" : "Alert message for keychain health check failure",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Schlüsselbund-Umgebung hat ein Problem. Bitte öffnen Sie die Schlüsselbundverwaltung, suchen Sie nach \"%@\", löschen Sie alle übereinstimmenden Einträge und starten Sie die App neu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The keychain environment has a problem. Please open Keychain Access, search for \"%@\", delete all matching items, then relaunch the app."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El entorno del llavero tiene un problema. Abre Acceso a Llaveros, busca \"%@\", elimina todos los elementos coincidentes y vuelve a abrir la aplicación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'environnement du trousseau a un problème. Veuillez ouvrir Trousseaux d'accès, rechercher « %@ », supprimer tous les éléments correspondants, puis relancer l'application."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キーチェーン環境に問題があります。キーチェーンアクセスを開き、「%@」を検索し、一致するすべてのアイテムを削除してからアプリを再起動してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "키체인 환경에 문제가 있습니다. 키체인 접근을 열고 \"%@\"를 검색하여 일치하는 모든 항목을 삭제한 다음 앱을 다시 실행하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "钥匙串环境存在问题。请打开\"钥匙串访问\"，搜索\"%@\"，删除所有匹配项，然后重新启动应用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "鑰匙圈環境發生問題。請開啟鑰匙圈存取，搜尋「%@」，刪除所有符合的項目，然後重新啟動應用程式。"
          }
        }
      }
    },
