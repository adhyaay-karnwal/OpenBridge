    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenBridge benötigt Mikrofonzugriff, um Sprachproben für die Audiogenerierung und das Voice-Cloning aufzunehmen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenBridge needs microphone access to record voice input in chat, run the voice demo, and create audio samples."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenBridge necesita acceso al micrófono para grabar muestras de voz para la generación de audio y la clonación de voz."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenBridge a besoin d'accéder au microphone pour enregistrer des échantillons vocaux pour la génération audio et le clonage vocal."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenBridgeは音声生成とボイスクローニングのための音声サンプルを録音するためにマイクへのアクセスが必要です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenBridge는 오디오 생성 및 음성 복제를 위한 음성 샘플을 녹음하기 위해 마이크 접근 권한이 필요합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenBridge 需要麦克风权限，才能在聊天中录制语音输入、运行语音 demo，以及创建音频样本。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenBridge 需要麥克風權限，才能在聊天中錄製語音輸入、執行語音 demo，以及建立音訊樣本。"
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription" : {
      "comment" : "Privacy - Speech Recognition Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenBridge needs speech recognition to turn your voice demo into editable text and actions."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenBridge 需要语音识别权限，才能把你的语音 demo 转成可编辑的文本和动作。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenBridge 需要語音辨識權限，才能把你的語音 demo 轉成可編輯的文字和動作。"
          }
        }
      }
    }
  },
  "version" : "1.1"
}