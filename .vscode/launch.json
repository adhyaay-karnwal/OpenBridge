{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Server",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend/cmd/server/main.go",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Launch Agent CLI",
      "type": "go",
      "request": "launch",
      "console": "integratedTerminal",
      "mode": "exec",
      "program": "${workspaceFolder}/sandbox-vm/dist/agent-cli",
      "args": [
        "--ssh-config"
      ],
      "cwd": "${workspaceFolder}/sandbox-vm",
      "preLaunchTask": "build-agent-cli-debug"
    },
    {
      "type": "swift",
      "request": "launch",
      "args": [],
      "cwd": "${workspaceFolder:cueboard}/macos/JSBridge",
      "name": "Debug JSBridgeBuildTool (macos/JSBridge)",
      "target": "JSBridgeBuildTool",
      "configuration": "debug",
      "preLaunchTask": "swift: Build Debug JSBridgeBuildTool (macos/JSBridge)"
    },
    {
      "type": "swift",
      "request": "launch",
      "args": [],
      "cwd": "${workspaceFolder:cueboard}/macos/JSBridge",
      "name": "Release JSBridgeBuildTool (macos/JSBridge)",
      "target": "JSBridgeBuildTool",
      "configuration": "release",
      "preLaunchTask": "swift: Build Release JSBridgeBuildTool (macos/JSBridge)"
    }
  ]
}
